# ---------- Network ----------
# mainnet | testnet
# NETWORK=mainnet
# TONCENTER_API_KEY=

# ---------- Wallet source: env (default) ----------
# Provide one TON 24-word mnemonic per wallet you want loaded.
# These produce addresses interoperable with Tonkeeper / Wallet.tg.
# WALLET_MNEMONIC_0="word1 word2 ... word24"
# WALLET_MNEMONIC_1="..."

# Or provide raw ed25519 secret keys (64 bytes hex, no 0x prefix).
# WALLET_PKEY_0=...
# WALLET_PKEY_1=...

# ---------- Wallet source: mnemonic (bulk) ----------
# A single mnemonic enumerated across subwallet_ids.
# Configure subwalletStart / subwalletNumber via `tonx config`.
# Subwallet addresses ARE NOT importable into stock TON wallet apps.
# MNEMONIC="word1 word2 ... word24"

# ---------- Optional ----------
# Hide password manager UID (only used if walletSource=hide)
# HIDE_UID=
# CRYPT_SECRET=
