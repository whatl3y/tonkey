{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-audit-comments.sh",
            "if": "Bash(git commit*)",
            "timeout": 15,
            "statusMessage": "Scanning staged diff for audit-prefix comments..."
          }
        ]
      }
    ]
  }
}
